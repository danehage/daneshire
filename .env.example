# Database (Neon Postgres)
NEON_DATABASE_URL=postgresql+asyncpg://user:password@ep-something.us-east-2.aws.neon.tech/dbname?sslmode=require

# Market Data
FMP_API_KEY=your_fmp_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here

# Tastytrade (options chains + IV; provision via one-time manual login — see DEPLOY.md)
TASTYTRADE_REMEMBER_TOKEN=your_tastytrade_remember_token

# Notifications (Pushover)
PUSHOVER_USER_KEY=your_pushover_user_key
PUSHOVER_API_TOKEN=your_pushover_app_token

# Alert Engine Auth (Cloud Scheduler → internal endpoints)
SCHEDULER_SECRET=generate_a_random_string_here

# Environment
ENVIRONMENT=development
