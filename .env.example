# Database (Neon Postgres)
NEON_DATABASE_URL=postgresql+asyncpg://user:password@ep-something.us-east-2.aws.neon.tech/dbname?sslmode=require

# Market Data
FMP_API_KEY=your_fmp_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here

# Tastytrade (options chains + IV via OAuth2; mint a refresh_token from
# Manage → API → OAuth Applications → Create Grant. See DEPLOY.md.)
TASTYTRADE_CLIENT_SECRET=your_tastytrade_oauth_client_secret
TASTYTRADE_REFRESH_TOKEN=your_tastytrade_oauth_refresh_token

# Vision Parsing (portfolio screenshot → structured JSON via Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Notifications (Pushover)
PUSHOVER_USER_KEY=your_pushover_user_key
PUSHOVER_API_TOKEN=your_pushover_app_token

# Alert Engine Auth (Cloud Scheduler → internal endpoints)
SCHEDULER_SECRET=generate_a_random_string_here

# Nightly backup (GCS bucket name, no gs:// prefix)
GCS_BACKUP_BUCKET=daneshire-db-backups

# Environment
ENVIRONMENT=development
